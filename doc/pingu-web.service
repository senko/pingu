[Unit]
Description=Pingu Web Server (gunicorn)
After=network.target

[Service]
Type=simple
User=exedev
Group=exedev
WorkingDirectory=/home/exedev/pingu
EnvironmentFile=/home/exedev/pingu/.env
ExecStart=/home/exedev/pingu/.venv/bin/python -m gunicorn pingu.wsgi:application --bind 0.0.0.0:8000 --workers 2 --pythonpath src
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
